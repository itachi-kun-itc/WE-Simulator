{
  "name": "weather-earthquake-simulator",
  "version": "0.1.1",
  "private": true,
  "homepage": "https://itachi-kun-itc.github.io/WE-Simulator/",
  "scripts": {
    "build:jma-earthquake-map": "node scripts/convert_jma_earthquake_areas.js",
    "build:jma-epicenter-areas": "node scripts/build_epicenter_areas.js",
    "build:jma-eew-forecast-areas": "node scripts/fetch_jma_eew_forecast_areas.js",
    "build:jma-shindo-stations": "node scripts/fetch_jma_shindo_stations.js",
    "build:earthquake-presets": "node scripts/build_earthquake_presets_from_csv.js",
    "build:municipalities": "node scripts/convert_n03_municipalities.js",
    "build:surrounding-land": "node scripts/convert_surrounding_land.js",
    "build:world-coastline": "node scripts/convert_world_coastline.js",
    "build:japan-land-overview": "node scripts/build_japan_land_overview.js",
    "build:eq-app-japan-land": "node scripts/import_eq_app_japan_land.js",
    "optimize:display-map": "node scripts/simplify_map_geojson.js --input web/data/surrounding_land.geojson --tolerance 0.018 --precision 4 --minRingArea 0.00025 && node scripts/simplify_map_geojson.js --input web/data/world_coastline.geojson --tolerance 0.01 --precision 4 && node scripts/simplify_map_geojson.js --input web/data/eq_app_japan_land.geojson --tolerance 0.0002 --precision 5 --minRingArea 0.0000002",
    "build:municipality-chunks": "node scripts/build_municipality_chunks.js",
    "build:ground": "node --max-old-space-size=8192 scripts/build_ground_model.js",
    "build:boundaries": "node --max-old-space-size=8192 scripts/build_boundary_layers.js",
    "upload:earthquake-presets": "node scripts/upload_earthquake_presets_to_worker.js",
    "check:encoding": "node scripts/check_text_encoding.js",
    "check:app": "npm run check:encoding && node --check web/app.js",
    "web": "node web/dev-server.js",
    "inject-version": "node scripts/inject_version.js",
    "preweb": "npm run check:encoding && npm run inject-version",
    "predeploy": "npm run check:encoding && npm run inject-version",
    "open-site": "node scripts/open_site.js",
    "public-site": "node scripts/public_site.js",
    "generate:vapid": "node scripts/generate_vapid_keys.js",
    "deploy": "gh-pages -d web"
  },
  "devDependencies": {
    "gh-pages": "^6.3.0",
    "localtunnel": "^2.0.2"
  }
}
